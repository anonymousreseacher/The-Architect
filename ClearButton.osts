{"version":"0.3.0","body":"\nfunction main(workbook: ExcelScript.Workbook) {\n    const sheet = workbook.getWorksheet(\"Architect\");\n\n    const arrowrange = sheet.getRangeByIndexes(4, 1, 50, 5);\n    arrowrange.setValue(\"\");\n\n    const messagerane = sheet.getRangeByIndexes(5, 6, 50, 2);\n    messagerane.setValue(\"\");\n    sheet.getCell(4,7).setValue(1);\n    sheet.getCell(4, 6).setValue(false);\n\n      const sheets = workbook.getWorksheets();\n\n      for (let i = sheets.length - 1; i >= 0; i--) {\n        const sheet = sheets[i];\n        const name = sheet.getName();\n\n        if (name.includes(\"Blueprint\")) {\n          sheet.delete();\n        }\n      }\n\n\n      let dashboardSheet = workbook.getWorksheet(\"Dashboard\");\n\n      if (dashboardSheet) {\n        dashboardSheet.delete();\n      }\n\n\n}\n","description":"","noCodeMetadata":"","parameterInfo":"{\"version\":1,\"originalParameterOrder\":[],\"parameterSchema\":{\"type\":\"object\",\"default\":{},\"x-ms-visibility\":\"internal\"},\"returnSchema\":{\"type\":\"object\",\"properties\":{}},\"signature\":{\"comment\":\"\",\"parameters\":[{\"name\":\"workbook\",\"comment\":\"\"}]}}","apiInfo":"{\"variant\":\"synchronous\",\"variantVersion\":2}"}